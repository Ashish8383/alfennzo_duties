{
  "expo": {
    "name": "Alfennzo duties",
    "slug": "waiter-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alfenzo.waiter"
    },
    "android": {
      "navigationBarColor": "#FFFFFF",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alfenzo.waiter"
    },
    "web": {
      "favicon": "./src/assets/images/adaptive-icon.png"
    },
    "experiments": {
      "tsconfigPaths": false
    }
  }
}